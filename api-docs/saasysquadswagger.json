{
  "swagger": "2.0",
  "info": {
    "description": "SaasySquad Backend for Sengg2021. Uses a bun backend, neon postgres, and redis cache all deployed on Vercel :).",
    "version": "1.0.0",
    "title": "SaasySquad API"
  },
  "host": "https://jasonlihav1234.github.io/sassysquad-backend",
  "basePath": "/api-docs",
  "tags": [
    {
      "name": "user",
      "description": "Operations about user"
    }
  ],
  "schemes": ["https", "http"],
  "securityDefinitions": {
    "accessToken": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Enter your bearer token in the format **Bearer token**"
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["user"],
        "summary": "Registers a user",
        "description": "",
        "operationId": "registerUser",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "User details to be registered",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email", "username", "password"],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "testing@gmail.com"
                },
                "username": {
                  "type": "string",
                  "example": "testUserName1234"
                },
                "password": {
                  "type": "string",
                  "example": "password"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User has been successfully registered",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                },
                "user": {
                  "description": "User ID of the registered user",
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          },
          "400": {
            "description": "Email, password, and user not supplied or password is less than 7 characters",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "409": {
            "description": "Registering email with someone that already exists",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "General error ocured during registration",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["user"],
        "summary": "Logs in a user",
        "description": "",
        "operationId": "login",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Login object needs a email and password",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email", "password"],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "testing@gmail.com"
                },
                "password": {
                  "type": "string",
                  "example": "password1234"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User successfully logged in",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "accessToken": {
                  "type": "string"
                },
                "refreshToken": {
                  "type": "string"
                },
                "tokenType": {
                  "type": "string"
                },
                "expiresIn": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          },
          "400": {
            "description": "Email and password not supplied",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Credentials provided are invalid",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "General error ocurred during login",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["user"],
        "summary": "Refreshes a refresh token",
        "description": "",
        "operationId": "refresh",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Users refresh token to be exchanged",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["refreshToken"],
              "properties": {
                "refreshToken": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Refresh token successfully exchanged",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "accessToken": {
                  "type": "string"
                },
                "refreshToken": {
                  "type": "string"
                },
                "tokenType": {
                  "type": "string"
                },
                "expiresIn": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          },
          "400": {
            "description": "Refresh token was not provided",
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Refresh token does not exist, or token has been revoked, or token is invalid",
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["user"],
        "summary": "Logs out a user",
        "description": "",
        "operationId": "logout",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Refresh token to revoke when logging out",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["refreshToken"],
              "properties": {
                "refereshToken": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User successfully logged out",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout-all": {
      "post": {
        "tags": ["user"],
        "summary": "Logs out all devices from a user",
        "description": "",
        "operationId": "logout-all",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "All devices have been logged out",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["user"],
        "summary": "Sends a forgot password email to given email if valid",
        "description": "",
        "operationId": "forgot-password",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Email to send forgot password to",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email"],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "testing@gmail.com"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Mail successfully sent",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Provided email not linked to any user",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "General error for failed email sending",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": ["user"],
        "summary": "Resets the password of a user",
        "description": "",
        "operationId": "reset-password",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Email of the user, token which was sent to reset password, and new password",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "example": "testing@gmail.com"
                },
                "token": {
                  "type": "string"
                },
                "password": {
                  "type": "string",
                  "example": "new_password1234"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Password successfully reset",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Missing token or password",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "New password is invalid",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Token has already expired or is invalid",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/clean-tokens": {
      "delete": {
        "tags": ["user"],
        "summary": "Deletes expired refresh tokens stored in the database",
        "description": "",
        "operationId": "clean-tokens",
        "produces": ["application/json"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Deleted any expired tokens",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/profile": {
      "get": {
        "tags": ["user"],
        "summary": "Fetches the details of logged in user",
        "description": "",
        "operationId": "get-profile",
        "produces": ["application/json"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Profile details successfully fetched",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                },
                "response": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "user_id": {
                        "type": "string"
                      },
                      "user_name": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string"
                      },
                      "password_hash": {
                        "type": "string"
                      },
                      "created_at": {
                        "type": "date-time"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "General error to fail getting user details",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["user"],
        "summary": "Updates the details of logged in user",
        "description": "",
        "operationId": "patch-profile",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Profile object needs atleast a email or password or username and an access token",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "example": "testing@gmail.com"
                },
                "username": {
                  "type": "string",
                  "example": "test_username"
                },
                "password": {
                  "type": "string",
                  "example": "new_password"
                },
                "accessToken": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User details successfully updated",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "No fields to update for the user",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized to make request",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "General error for failure to update profile",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["user"],
        "summary": "Deletes a user",
        "description": "",
        "operationId": "delete-profile",
        "produces": ["application/json"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "User successfully deleted",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "interger",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                },
                "response": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "user_id": {
                        "type": "string"
                      },
                      "user_name": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string"
                      },
                      "password_hash": {
                        "type": "string"
                      },
                      "created_at": {
                        "type": "date-time"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "General failure to delete user error",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/sessions": {
      "get": {
        "tags": ["user"],
        "summary": "Gets all active sessions of a user",
        "description": "",
        "operationId": "sessions",
        "produces": ["application/json"],
        "security": {
          "bearerAuth": []
        },
        "parameters": [],
        "responses": {
          "200": {
            "description": "Getting all user sessions successful",
            "schema": {
              "type": "object",
              "properties": {
                "deviceInfo": {
                  "type": "object"
                },
                "createdAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "expiresAt": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      }
    },
    "/users/{userId}": {
      "get": {
        "tags": ["user"],
        "summary": "Retrieves the details of a user given a user ID",
        "description": "",
        "operationId": "user-userId",
        "produces": ["application/json"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "Unique identifier of user",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User details successfully fetched",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                },
                "response": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "user_id": {
                        "type": "string"
                      },
                      "user_name": {
                        "type": "string"
                      },
                      "email": {
                        "type": "string"
                      },
                      "password_hash": {
                        "type": "string"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "General error for failed fetching of user details",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
