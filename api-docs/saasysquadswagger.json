{
  "swagger": "2.0",
  "info": {
    "description": "SaasySquad Backend for Sengg2021. Uses a bun backend, neon postgres, and redis cache all deployed on Vercel :).",
    "version": "1.0.0",
    "title": "SaasySquad API"
  },
  "host": "https://jasonlihav1234.github.io/sassysquad-backend/",
  "basePath": "/api-docs",
  "tags": [
    {
      "name": "user",
      "description": "Operations about user"
    }
  ],
  "schemas": ["https", "http"],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["user"],
        "summary": "Registers a user",
        "description": "",
        "operationId": "registerUser",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "User details to be registered",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email", "username", "password"],
              "properties": {
                "email": {
                  "type": "string",
                  "exmaple": "testing@gmail.com"
                },
                "username": {
                  "type": "string",
                  "example": "testUserName1234"
                },
                "password": {
                  "type": "string",
                  "example": "password"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User has been successfully registered",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "message": {
                  "type": "string"
                },
                "user": {
                  "description": "User ID of the registered user",
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          },
          "400": {
            "description": "Email, password, and user not supplied or password is less than 7 characters",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "409": {
            "description": "Registering email with someone that already exists",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "General error ocured during registration",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["login"],
        "summary": "Logs in a user",
        "description": "",
        "operationId": "login",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Login object needs a email and password",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email", "password"],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "testing@gmail.com"
                },
                "password": {
                  "type": "string",
                  "exmaple": "password1234"
                }
              }
            }
          }
        ],
        "response": {
          "200": {
            "description": "User successfully logged in",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "accessToken": {
                  "type": "string"
                },
                "refreshToken": {
                  "type": "string"
                },
                "tokenType": {
                  "type": "string"
                },
                "expiresIn": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          },
          "400": {
            "description": "Email and password not supplied",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Credentials provided are invalid",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "General error ocurred during login",
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "format": "int32"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
